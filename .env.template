# Job-Search-Go — environment configuration.
# Copy this file to .env and fill in real values:  cp .env.template .env
# .env is gitignored and must never be committed.

# Apify — LinkedIn ingest (free tier).
# Token: https://console.apify.com/account/integrations
APIFY_USER=
APIFY_TOKEN=
# Apify Actor id for LinkedIn ingest — public, not a secret.
# Default: curious_coder/linkedin-jobs-scraper. Override to use a different Actor.
APIFY_ACTOR_ID=hKByXkMQaC5Qt9UMN

# Anthropic — Claude verification step.
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
